{
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/identities/{**catch-all}" }
      },
      "repo-route": {
        "ClusterId": "repo-cluster",
        "Match": { "Path": "/api/repositories/{**catch-all}" }
      },
      "syncing-route": {
        "ClusterId": "syncing-cluster",
        "Match": { "Path": "/api/sync/{**catch-all}" }
      },
      "issue-route": {
        "ClusterId": "issue-cluster",
        "Match": { "Path": "/api/issues/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://identity:8000/" }
        }
      },
      "repo-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://repository:8000/" }
        }
      },
      "syncing-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://syncing:8000/" }
        }
      },
      "issue-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://issue:8000/" }
        }
      }
    }
  }
}
